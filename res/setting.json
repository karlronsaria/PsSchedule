{
    "EditCommand": "nvim",
    "ScheduleDirectory": "/note/sched/notebook",
    "ScheduleExtension": "*.md",
    "ScheduleDefaultSubdirectory": "general",
    "ScheduleDefaultsFile": "default.json",
    "SearchDirectory": "/note",
    "IgnoreSubdirectories": [
        "__OLD",
        "__SHELF"
    ],
    "RotateSubtreeOnProperties": [],
    "MuteProperties": [
        "log"
    ],
    "NoteReschedule": [
        "", "reschedule", "resched", "reappoint"
    ],
    "NoteNotActive": [
        "not-active", "not active", "deactive", "deactivate"
    ],
    "Addendum": {
        "Typename": "sched addendum",
        "FilePattern": "rule"
    },
    "TagPrefix": "#",
    "MoveItem": {
        "IgnoreSubdirectories": [
            "__OLD"
        ]
    }
}

